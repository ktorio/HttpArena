{
  "server": {
    "address": "0.0.0.0",
    "port": 8081,
    "max_connections": 512,
    "static_root": "/data/static",
    "workers": 0,
    "disable_middleware": true
  },
  "buffer_pool": {
    "buffer_size": 65536,
    "buffer_count": 1024
  },
  "tls": {
    "cert_path": "/certs/server.crt",
    "key_path": "/certs/server.key"
  },
  "http2": {
    "max_streams": 256,
    "initial_window_size": 1048576
  }
}
